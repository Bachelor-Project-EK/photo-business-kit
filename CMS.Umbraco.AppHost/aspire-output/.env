# Parameter db-password
DB_PASSWORD=

# Parameter sql-password
SQL_PASSWORD=

# Bind mount source for umbraco-cms:/app_data
UMBRACO_CMS_BINDMOUNT_0=

# Container image name for umbraco-cms
UMBRACO_CMS_IMAGE=

# Container image name for umbraco-db
UMBRACO_DB_IMAGE=

