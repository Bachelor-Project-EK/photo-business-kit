# Bind mount source for cms-umbraco:/app/wwwroot/media
CMS_UMBRACO_BINDMOUNT_0=

# Bind mount source for cms-umbraco:/app/wwwroot/scripts
CMS_UMBRACO_BINDMOUNT_1=

# Bind mount source for cms-umbraco:/app/wwwroot/css
CMS_UMBRACO_BINDMOUNT_2=

# Bind mount source for cms-umbraco:/app/Views
CMS_UMBRACO_BINDMOUNT_3=

# Bind mount source for cms-umbraco:/app/umbraco/models
CMS_UMBRACO_BINDMOUNT_4=

# Container image name for cms-umbraco
CMS_UMBRACO_IMAGE=

# Default container port for cms-umbraco
